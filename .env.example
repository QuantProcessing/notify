# ============================================================
# Feishu (Lark) Configuration
# ============================================================

# Webhook URL for sending bot messages (required for webhook mode)
FEISHU_WEBHOOK=https://open.feishu.cn/open-apis/bot/v2/hook/your-webhook-id

# Lark App ID (optional, required for SDK features like urgent calls)
FEISHU_APP_ID=cli_xxxxxxxxxxxx

# Lark App Secret (optional, required for SDK features like urgent calls)
FEISHU_APP_SECRET=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# User Open ID (optional, required for phone urgent calls)
FEISHU_USER_OPEN_ID=ou_xxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================
# Telegram Configuration
# ============================================================

# Telegram Bot Token (required)
TELEGRAM_BOT_TOKEN=123456789:ABCdefGHIjklMNOpqrsTUVwxyz

# Telegram Chat IDs, comma-separated (first is default for Notify)
TELEGRAM_CHAT_ID=123456789,987654321
